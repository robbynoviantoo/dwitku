// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH (NextAuth.js) ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   WorkspaceMember[]
  invitesSent   Invite[]          @relation("InviteSender")
  transactions  Transaction[]
  sales         Sale[]
  saleExpenses  SaleExpense[]
  subscription  Subscription?
  pushSubscriptions PushSubscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// ─── WORKSPACE ───────────────────────────────────────────────────────────────

enum WorkspaceType {
  FINANCE
  SALES
}

model Workspace {
  id          String        @id @default(cuid())
  name        String
  description String?
  currency    String        @default("IDR")
  isPersonal  Boolean       @default(false)
  type        WorkspaceType @default(FINANCE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members      WorkspaceMember[]
  categories   Category[]
  transactions Transaction[]
  invites      Invite[]
  sales        Sale[]
  saleExpenses SaleExpense[]
  products     Product[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

// ─── INVITE ──────────────────────────────────────────────────────────────────

model Invite {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(EDITOR)
  token       String        @unique @default(cuid())
  status      InviteStatus  @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  senderId    String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sender    User      @relation("InviteSender", fields: [senderId], references: [id])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// ─── KATEGORI ────────────────────────────────────────────────────────────────

model Category {
  id          String          @id @default(cuid())
  name        String
  emoji       String          @default("📁")
  color       String          @default("#16a34a")
  type        TransactionType @default(EXPENSE)
  isDefault   Boolean         @default(false)
  workspaceId String
  createdAt   DateTime        @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  sales        Sale[]
  saleExpenses SaleExpense[]
  products     Product[]
}

model Product {
  id          String   @id @default(cuid())
  workspaceId String
  categoryId  String?
  name        String
  costPrice   Decimal  @default(0) @db.Decimal(15, 2) // HPP per satuan
  packages    Json?    // Array konfigurasi: [{ price: 5000, qty: 7 }, { price: 7000, qty: 10 }]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id])
  sales     Sale[]
}

// ─── TRANSAKSI ───────────────────────────────────────────────────────────────

model Transaction {
  id          String          @id @default(cuid())
  amount      Decimal         @db.Decimal(15, 2)
  note        String?
  date        DateTime
  type        TransactionType
  workspaceId String
  categoryId  String
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ─── PENJUALAN ───────────────────────────────────────────────────────────────

// Satu entri = satu item yang dijual dalam satu transaksi
model Sale {
  id           String   @id @default(cuid())
  workspaceId  String
  productId    String?
  date         DateTime
  categoryId   String?
  name         String   // nama produk / item (snapshot)
  qty          Decimal  @default(1) @db.Decimal(10, 3)
  sellingPrice Decimal  @db.Decimal(15, 2)  // harga jual per unit
  costPrice    Decimal  @default(0) @db.Decimal(15, 2) // HPP per unit
  note         String?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
}

// Biaya operasional harian (untuk mengurangi laba kotor → laba bersih)
model SaleExpense {
  id          String   @id @default(cuid())
  workspaceId String
  date        DateTime
  categoryId  String?
  name        String   // nama biaya (contoh: gaji, listrik, bahan baku)
  amount      Decimal  @db.Decimal(15, 2)
  note        String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
}

// ─── PLAN ───────────────────────────────────────────────────────────────────

model Plan {
  id            String   @id @default(cuid())
  key           String   @unique  // "free" | "basic" | "pro"
  name          String
  priceMonthly  Int      @default(0)  // dalam rupiah
  maxWorkspaces Int      @default(2)  // -1 = unlimited
  maxMembers    Int      @default(5)  // -1 = unlimited
  maxTx         Int      @default(200) // -1 = unlimited
  maxCategories Int      @default(1)  // custom categories; -1 = unlimited
  canExport     Boolean  @default(false)
  canReport     Boolean  @default(false)
  trialDays     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  subscriptions Subscription[]
}

// ─── SUBSCRIPTION ───────────────────────────────────────────────────────────

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  planId           String
  status           SubscriptionStatus @default(TRIAL)
  midtransOrderId  String?            @unique
  midtransToken    String?
  startedAt        DateTime           @default(now())
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  payments Payment[]
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

// ─── PAYMENT ─────────────────────────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  subscriptionId  String
  orderId         String        @unique
  amount          Int
  status          PaymentStatus @default(PENDING)
  midtransData    Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([endpoint])
}
